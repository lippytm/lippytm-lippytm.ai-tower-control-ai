{
  "name": "ai-tower-control",
  "version": "1.0.0",
  "description": "AI Control Tower – connects ChatGPT/OpenAI with AllBots.com.ai, Factory.ai, Replit and GitHub Copilot with cybersecurity and automated data management",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint src tests"
  },
  "keywords": [
    "ai",
    "control-tower",
    "chatgpt",
    "openai",
    "allbots",
    "factory-ai",
    "replit",
    "github-copilot",
    "cybersecurity"
  ],
  "author": "lippytm",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.57.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
