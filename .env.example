# AI Control Tower – Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to source control.

# Server
PORT=3000
NODE_ENV=development

# JWT secret for API authentication (generate a long random string)
JWT_SECRET=replace_with_a_long_random_secret

# OpenAI / ChatGPT
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Perplexity AI
PERPLEXITY_API_KEY=your_perplexity_api_key
PERPLEXITY_MODEL=sonar

# AllBots.com.ai
ALLBOTS_API_KEY=your_allbots_api_key
ALLBOTS_BASE_URL=https://api.allbots.com.ai

# Factory.ai
FACTORY_AI_API_KEY=your_factory_ai_api_key
FACTORY_AI_BASE_URL=https://api.factory.ai

# Replit
REPLIT_API_KEY=your_replit_api_key
REPLIT_BASE_URL=https://replit.com/api/v1

# GitHub (Copilot / API)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_github_repo

# BotBuilders
BOTBUILDERS_API_KEY=your_botbuilders_api_key
BOTBUILDERS_BASE_URL=https://api.botbuilders.com/v1

# ManyChat
MANYCHAT_API_KEY=your_manychat_api_key

# Kartra
KARTRA_API_KEY=your_kartra_api_key
KARTRA_APP_PASSWORD=your_kartra_app_password
KARTRA_BASE_URL=https://app.kartra.com/api

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
