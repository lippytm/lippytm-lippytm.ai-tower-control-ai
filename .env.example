# AI Control Tower – Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to source control.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# JWT secret for API authentication (generate a long random string, minimum 32 characters)
JWT_SECRET=CHANGEME_REPLACE_WITH_32_PLUS_RANDOM_CHARS

# OpenAI / ChatGPT
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# AllBots.com.ai
ALLBOTS_API_KEY=your_allbots_api_key
ALLBOTS_BASE_URL=https://api.allbots.com.ai

# Factory.ai
FACTORY_AI_API_KEY=your_factory_ai_api_key
FACTORY_AI_BASE_URL=https://api.factory.ai

# Replit
REPLIT_API_KEY=your_replit_api_key
REPLIT_BASE_URL=https://replit.com/api/v1

# GitHub (Copilot / API)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_github_repo

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS – comma-separated list of allowed origins (leave unset to allow all origins)
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Webhook dispatcher (used by .github/workflows/webhook.yml)
TOWER_API_URL=https://your-deployed-tower-url
TOWER_CLIENT_ID=your_client_id
TOWER_CLIENT_SECRET=your_client_secret
