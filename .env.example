# AI Control Tower – Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to source control.

# Server
PORT=3000
NODE_ENV=development

# JWT secret for API authentication (generate a long random string, e.g. openssl rand -hex 64)
JWT_SECRET=replace_with_a_long_random_secret

# OpenAI / ChatGPT
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# AllBots.com.ai
ALLBOTS_API_KEY=your_allbots_api_key
ALLBOTS_BASE_URL=https://api.allbots.com.ai

# Factory.ai
FACTORY_AI_API_KEY=your_factory_ai_api_key
FACTORY_AI_BASE_URL=https://api.factory.ai

# Replit
REPLIT_API_KEY=your_replit_api_key
REPLIT_BASE_URL=https://replit.com/api/v1

# GitHub (Copilot / API)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_github_repo

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS – comma-separated list of allowed origins (e.g. https://app.example.com,https://admin.example.com)
# Leave empty to block all cross-origin browser requests (recommended for API-only services)
CORS_ORIGIN=

# Logging – one of: error, warn, info, http, verbose, debug, silly
# Defaults to 'warn' in production, 'info' otherwise
LOG_LEVEL=

# Graceful shutdown timeout (ms) before force-killing the process
SHUTDOWN_TIMEOUT_MS=10000

# Set to 'true' ONLY in test environments to bypass rate limiting
DISABLE_RATE_LIMIT=false
